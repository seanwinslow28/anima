  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "vector lines, solid black ink, cel shading, anime style, digital art, gradient shading, airbrush, pure white background, saturated colors, vibrant colors, photorealistic, 3D render, smooth clean lines, watermark, text, blurry, deformed",
      "clip": ["1", 1]
